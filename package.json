{
  "name": "bloom",
  "private": false,
  "version": "0.1.0-alpha.1",
  "description": "A local-first desktop companion app shell for macOS, Windows, and Linux.",
  "homepage": "https://github.com/vivaanseth/bloom#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vivaanseth/bloom.git"
  },
  "bugs": {
    "url": "https://github.com/vivaanseth/bloom/issues"
  },
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "scan:privacy": "node scripts/privacy-scan.mjs",
    "release:check": "node scripts/verify-release-metadata.mjs",
    "release:collect": "node scripts/collect-tauri-artifacts.mjs",
    "release:verify-assets": "node scripts/verify-release-assets.mjs",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "tauri:build:no-bundle": "tauri build --no-bundle"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^24.0.13",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.31.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.37.0",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
